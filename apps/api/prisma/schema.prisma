// Finanzas Personales — Prisma Schema
// Generado: 04 de julio de 2026
// Revisado: 16 de julio de 2026 — ownership y schema de préstamos por cobrar

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  displayName         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  accounts            Account[]
  categories          Category[]
  transactions        Transaction[]
  commitmentTemplates CommitmentTemplate[]
  commitments         Commitment[]
  goals               Goal[]
  loans               Loan[]             @relation("UserLoans")
  loanRepayments      LoanRepayment[]    @relation("UserLoanRepayments")

  @@map("users")
}

// ─────────────────────────────────────────────
// CUENTAS
// ─────────────────────────────────────────────

model Account {
  id           String      @id @default(cuid())
  nombre       String
  tipo         AccountType
  saldo        Int         // en pesos chilenos, sin decimales
  activa       Boolean     @default(true)
  notas        String?
  orden        Int         @default(0) // para ordenar en el dashboard
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  transacciones Transaction[]
  metas         Goal[]

  @@index([userId])
  @@unique([id, userId])
  @@map("accounts")
}

enum AccountType {
  OPERATIVA   // Cuenta principal, cuenta secundaria
  AHORRO      // Cuenta de ahorro, reserva de objetivo
  DEUDA       // Tarjeta de crédito, crédito de consumo
  RESERVA     // Fondo de reserva, colchón de emergencia
}

// ─────────────────────────────────────────────
// CATEGORÍAS
// ─────────────────────────────────────────────

model Category {
  id            String       @id @default(cuid())
  nombre        String
  icono         String       // nombre del ícono (ej: "car", "shopping-cart")
  tipo          CategoryType
  orden         Int          @default(0)

  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  transacciones Transaction[]

  @@index([userId])
  @@unique([id, userId])
  @@unique([userId, nombre])
  @@map("categories")
}

enum CategoryType {
  GASTO
  INGRESO
}

// ─────────────────────────────────────────────
// TRANSACCIONES
// ─────────────────────────────────────────────

model Transaction {
  id              String          @id @default(cuid())
  tipo            TransactionType
  monto           Int             // siempre positivo, el tipo define si suma o resta
  descripcion     String
  fecha           DateTime        @default(now())
  notas           String?

  // Relaciones
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  accountId       String
  account         Account         @relation(fields: [accountId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)

  categoryId      String?
  category        Category?       @relation(fields: [categoryId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)

  // Vínculo para transferencias entre cuentas propias
  // Ambos movimientos (salida + entrada) comparten el mismo transferId
  transferId      String?         // UUID generado al crear la transferencia

  // Vínculo opcional cuando la transacción fue creada al pagar un compromiso.
  commitmentPayment Commitment?    @relation("CommitmentPayment")
  loanDelivery       Loan?          @relation("LoanDelivery")
  loanRepayment      LoanRepayment? @relation("LoanRepaymentTransaction")

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([accountId])
  @@index([fecha])
  @@index([transferId])
  @@unique([id, userId])
  @@map("transactions")
}

enum TransactionType {
  INGRESO       // plata que entra a la cuenta
  GASTO         // plata que sale de la cuenta
  TRANSFERENCIA // movimiento vinculado a otro (comparte transferId)
}

// ─────────────────────────────────────────────
// PRÉSTAMOS POR COBRAR
// ─────────────────────────────────────────────
// Un Loan representa una entrega independiente a una persona. El saldo
// pendiente se deriva de montoEntregado menos la suma de devoluciones.

model Loan {
  id                    String          @id @default(cuid())
  persona               String
  montoEntregado        Int             // siempre positivo; saldo pendiente es derivado
  estado                LoanStatus      @default(PENDIENTE)
  notas                 String?
  entregaTransactionId  String          @unique
  userId                String

  user                  User            @relation("UserLoans", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  entregaTransaction    Transaction     @relation("LoanDelivery", fields: [entregaTransactionId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)
  devoluciones          LoanRepayment[]  @relation("LoanRepaymentLoan")

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([userId])
  @@index([userId, estado])
  @@unique([id, userId])
  @@unique([entregaTransactionId, userId])
  @@map("loans")
}

model LoanRepayment {
  id              String      @id @default(cuid())
  monto           Int         // siempre positivo; el saldo pendiente se calcula desde el historial
  loanId          String
  transactionId   String      @unique
  userId          String

  loan            Loan        @relation("LoanRepaymentLoan", fields: [loanId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)
  transaction     Transaction @relation("LoanRepaymentTransaction", fields: [transactionId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)
  user            User        @relation("UserLoanRepayments", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([userId, loanId])
  @@index([loanId])
  @@unique([transactionId, userId])
  @@map("loan_repayments")
}

enum LoanStatus {
  PENDIENTE
  SALDADO
  INCOBRABLE
}

// ─────────────────────────────────────────────
// COMPROMISOS MENSUALES
// ─────────────────────────────────────────────

model Commitment {
  id              String           @id @default(cuid())
  nombre          String
  tipo            CommitmentType
  monto           Int              // monto esperado; puede editarse si varía (ej: luz)
  estado          CommitmentStatus @default(PENDIENTE)
  fechaVencimiento DateTime?       // día del mes en que vence
  mes             Int              // 1-12
  anio            Int
  notas           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Vínculo opcional a la plantilla recurrente que originó esta instancia.
  // Null para compromisos VARIABLE (luz, agua) o cargados manualmente sin plantilla.
  templateId      String?
  template        CommitmentTemplate? @relation(fields: [templateId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)

  // Transacción GASTO creada por el pago de este compromiso.
  paymentTransactionId String?      @unique
  paymentTransaction   Transaction? @relation("CommitmentPayment", fields: [paymentTransactionId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@unique([paymentTransactionId, userId])
  @@index([mes, anio])
  @@index([templateId])
  @@unique([templateId, anio, mes])
  @@map("commitments")
}

// ─────────────────────────────────────────────
// PLANTILLAS DE COMPROMISOS RECURRENTES
// ─────────────────────────────────────────────
// Separa la definición recurrente (ej. "Play", $X, vence el día 5)
// de la instancia mensual real (Commitment). Permite pausar un
// recurrente sin afectar el histórico: si `activa = false`, no se
// genera una nueva instancia para el mes siguiente.

model CommitmentTemplate {
  id             String         @id @default(cuid())
  nombre         String
  tipo           CommitmentType // normalmente RECURRENTE
  montoDefault   Int            // monto usado al generar cada instancia mensual
  diaVencimiento Int?           // día del mes en que vence, ej. 5
  activa         Boolean        @default(true) // si es false, no se genera instancia el próximo mes
  notas          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  instancias     Commitment[]

  @@index([userId])
  @@unique([id, userId])
  @@map("commitment_templates")
}

enum CommitmentType {
  RECURRENTE    // Netflix, Spotify, plan celular — mismo monto cada mes
  DEUDA         // Tarjeta, cuotas — monto fijo hasta saldar
  VARIABLE      // Luz, agua — monto cambia cada mes
}

enum CommitmentStatus {
  PENDIENTE
  PAGADO
}

// ─────────────────────────────────────────────
// METAS DE AHORRO
// ─────────────────────────────────────────────

model Goal {
  id              String     @id @default(cuid())
  nombre          String
  montoObjetivo   Int        // cuánto se quiere llegar a tener
  estado          GoalStatus @default(ACTIVA)
  notas           String?

  // Cuenta dedicada donde vive el dinero de esta meta
  // El progreso se calcula dinámicamente desde account.saldo
  accountId       String
  account         Account    @relation(fields: [accountId, userId], references: [id, userId], onDelete: Restrict, onUpdate: Cascade)

  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId])
  @@unique([id, userId])
  @@map("goals")
}

enum GoalStatus {
  ACTIVA
  PAUSADA
  COMPLETADA
}
